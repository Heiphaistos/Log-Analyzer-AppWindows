<Window x:Class="WinLogAnalyzer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WinLogAnalyzer.App.Views"
        Title="WinLog Analyzer" Height="820" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Topbar -->
        <Border Grid.Row="0" Background="{StaticResource BgElev}" BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1" Padding="28,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x26A1;" FontSize="26" VerticalAlignment="Center"
                           Foreground="#4C8DFF" Margin="0,0,12,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="WinLog Analyzer" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Diagnostic Windows — evenements &amp; planificateur de taches (v1.0)"
                               Foreground="{StaticResource TextDim}" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Onglets -->
        <TabControl Grid.Row="1" Padding="0" Margin="0,8,0,0">
            <TabItem Header="Evenements">
                <views:EventsView DataContext="{Binding Events}" />
            </TabItem>
            <TabItem Header="Planificateur de taches">
                <views:TasksView DataContext="{Binding Tasks}" />
            </TabItem>
            <TabItem Header="Incidents">
                <views:IncidentsView DataContext="{Binding Incidents}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
